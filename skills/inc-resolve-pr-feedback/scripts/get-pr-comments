#!/usr/bin/env bash

# Fetches PR review feedback. REST-first for everything that REST can do
# (comment bodies, top-level conversation, review submissions, PR author).
# GraphQL is used only to get thread-level state (thread IDs, isResolved,
# isOutdated) — and even that is fetched once per (PR, head SHA) and cached
# by the shared gh-thread-cache helper.
#
# When GraphQL is unavailable, this script does NOT block. It returns all
# inline comments as if every thread were actionable, with degraded: true so
# the caller can surface the limitation to the user.
#
# Output schema (unchanged from prior GraphQL-only version):
#   review_threads   - inline review threads to act on (unresolved + non-outdated when known)
#   pr_comments      - top-level PR conversation comments (excludes PR author + known review bots)
#   review_bodies    - review submission bodies (excludes PR author + known review bots)
#   cross_invocation - { signal, resolved_threads } for cluster analysis
#   degraded         - true when thread-state filtering could not be applied

set -e

if [ $# -lt 1 ]; then
    echo "Usage: get-pr-comments PR_NUMBER [OWNER/REPO]" >&2
    echo "Example: get-pr-comments 123" >&2
    echo "Example: get-pr-comments 123 EveryInc/cora" >&2
    exit 1
fi

PR_NUMBER=$1

if [ -n "$2" ]; then
    OWNER=$(echo "$2" | cut -d/ -f1)
    REPO=$(echo "$2" | cut -d/ -f2)
else
    OWNER=$(gh repo view --json owner -q .owner.login 2>/dev/null)
    REPO=$(gh repo view --json name -q .name 2>/dev/null)
fi

if [ -z "$OWNER" ] || [ -z "$REPO" ]; then
    echo "Error: Could not detect repository. Pass OWNER/REPO as second argument." >&2
    echo "  Manual: gh repo view --json owner,name" >&2
    exit 1
fi

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
THREAD_CACHE="$SCRIPT_DIR/../../../scripts/gh-thread-cache"
if [ ! -x "$THREAD_CACHE" ]; then
    # Fall back to PATH lookup or plugin layout.
    THREAD_CACHE=$(command -v gh-thread-cache || echo "")
fi

# REST: top-level PR conversation comments.
PR_ISSUE_COMMENTS=$(gh api "repos/$OWNER/$REPO/issues/$PR_NUMBER/comments" --paginate 2>/dev/null || echo "[]")

# REST: inline review comments (one row per comment, threaded via in_reply_to_id).
PR_REVIEW_COMMENTS=$(gh api "repos/$OWNER/$REPO/pulls/$PR_NUMBER/comments" --paginate 2>/dev/null || echo "[]")

# REST: review submissions (the "body" of a Review, plus state).
PR_REVIEWS=$(gh api "repos/$OWNER/$REPO/pulls/$PR_NUMBER/reviews" --paginate 2>/dev/null || echo "[]")

# REST: PR metadata (we need the author login to filter their own comments out).
PR_META=$(gh api "repos/$OWNER/$REPO/pulls/$PR_NUMBER" 2>/dev/null || echo "{}")
PR_AUTHOR=$(echo "$PR_META" | jq -r '.user.login // ""')

# GraphQL (cached): thread-state map. Tolerates failure.
THREAD_MAP_JSON="[]"
DEGRADED=false
if [ -n "$THREAD_CACHE" ]; then
    if THREAD_MAP_JSON=$("$THREAD_CACHE" get "$OWNER" "$REPO" "$PR_NUMBER" 2>/dev/null); then
        :
    else
        # Exit 2 = quota/auth degradation; exit 1 = parse/other error. Either way, degrade.
        DEGRADED=true
        THREAD_MAP_JSON="[]"
        echo "get-pr-comments: GraphQL thread-state unavailable; returning all inline comments without resolution filtering." >&2
        echo "  Manual rehydration once quota resets: $THREAD_CACHE get $OWNER $REPO $PR_NUMBER" >&2
    fi
else
    DEGRADED=true
    echo "get-pr-comments: gh-thread-cache helper not found; thread-state filtering disabled." >&2
fi

# Extract the threads array from the cache envelope (or use as-is if already an array).
THREADS=$(echo "$THREAD_MAP_JSON" | jq -c 'if type == "object" then .threads else . end' 2>/dev/null || echo "[]")

# Compose final output. Logic:
# - When THREADS is non-empty: group inline comments by thread (using thread map's comment IDs),
#   filter for unresolved + non-outdated, build review_threads.
# - When THREADS is empty (degraded): synthesize one "thread" per top-level inline comment
#   (in_reply_to_id == null), collect replies under it.
jq -n \
    --argjson issue_comments "$PR_ISSUE_COMMENTS" \
    --argjson review_comments "$PR_REVIEW_COMMENTS" \
    --argjson reviews "$PR_REVIEWS" \
    --argjson threads "$THREADS" \
    --arg author "$PR_AUTHOR" \
    --argjson degraded "$DEGRADED" '
def review_bot_logins:
  ["coderabbitai", "chatgpt-codex-connector", "gemini-code-assist",
   "copilot-pull-request-reviewer", "codecov"];

def is_review_bot: . as $login | review_bot_logins | index($login) != null;

# Index REST inline comments by their GraphQL node_id for thread-map lookup.
($review_comments | map({key: .node_id, value: .}) | from_entries) as $by_node |

# Build review_threads. Two paths depending on whether the thread map is available.
($threads
  | if length > 0 then
      map(select(.isResolved == false and .isOutdated == false))
      | map({
          id: .thread_id,
          isResolved: .isResolved,
          isOutdated: .isOutdated,
          path: .path,
          line: .line,
          comments: {
            nodes: [
              .comments[]
              | $by_node[.id]
              | select(. != null)
              | {
                  id: .node_id,
                  author: { login: .user.login },
                  body: .body,
                  createdAt: .created_at,
                  url: .html_url
                }
            ]
          }
        })
    else
      # Degraded path: synthesize threads from REST in_reply_to_id chains.
      # No isResolved info, so every chain is treated as actionable.
      ($review_comments
        | map(select(.in_reply_to_id == null))
        | map(. as $root |
            {
              id: ("REST_THREAD_" + ($root.id | tostring)),
              isResolved: null,
              isOutdated: null,
              path: $root.path,
              line: ($root.line // $root.original_line),
              comments: {
                nodes: (
                  [$root] + ($review_comments | map(select(.in_reply_to_id == $root.id)))
                  | map({
                      id: .node_id,
                      author: { login: .user.login },
                      body: .body,
                      createdAt: .created_at,
                      url: .html_url
                    })
                )
              }
            }))
    end
) as $review_threads |

# Resolved threads for cross-invocation awareness (only meaningful when not degraded).
($threads
  | map(select(.isResolved == true))
  | map({
      thread_id: .thread_id,
      path: .path,
      line: .line,
      first_comment_body: (.comments[0].id as $cid | $by_node[$cid].body // null),
      last_comment_at: (
        [.comments[].id | . as $cid | $by_node[$cid].created_at]
        | map(select(. != null)) | sort | last
      )
    })
  | sort_by(.last_comment_at)
  | .[-10:]
  | reverse
) as $resolved |

{
  review_threads: $review_threads,
  pr_comments: [$issue_comments[]
    | select(.user.login != $author)
    | select(.user.login | is_review_bot | not)
    | select(.body | test("^\\s*$") | not)
    | {
        id: .node_id,
        author: { login: .user.login },
        body: .body
      }],
  review_bodies: [$reviews[]
    | select(.body != null and .body != "")
    | select(.user.login != $author)
    | select(.user.login | is_review_bot | not)
    | {
        id: .node_id,
        author: { login: .user.login },
        body: .body,
        state: .state
      }],
  cross_invocation: {
    signal: (($resolved | length) > 0 and ($review_threads | length) > 0),
    resolved_threads: $resolved
  },
  degraded: $degraded
}'
